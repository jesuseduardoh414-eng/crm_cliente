# Supabase expone dos poolers y Prisma necesita los dos:
#   DATABASE_URL -> modo transaccion (6543), lo usa la app
#   DIRECT_URL   -> modo sesion (5432), lo usan las migraciones
# Sin DIRECT_URL, prisma migrate falla contra pgbouncer en modo transaccion.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.PROJECT_REF:PASSWORD@REGION.pooler.supabase.com:5432/postgres

JWT_SECRET=define_un_secreto_seguro
FRONTEND_URL=https://tu-frontend.vercel.app

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu-correo@dominio.com
EMAIL_PASS=tu-password-o-app-password
EMAIL_FROM="CRM <tu-correo@dominio.com>"

CORREO_USUARIO=tu-correo@dominio.com
CORREO_PASSWORD=tu-password-o-app-password
