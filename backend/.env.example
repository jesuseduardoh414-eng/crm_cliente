# Supabase expone dos poolers y Prisma necesita los dos:
#   DATABASE_URL -> modo transaccion (6543), lo usa la app
#   DIRECT_URL   -> modo sesion (5432), lo usan las migraciones
# Sin DIRECT_URL, prisma migrate falla contra pgbouncer en modo transaccion.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.PROJECT_REF:PASSWORD@REGION.pooler.supabase.com:5432/postgres

JWT_SECRET=define_un_secreto_seguro
FRONTEND_URL=https://tu-frontend.vercel.app

# Almacenamiento de archivos: adjuntos, fotos de perfil e imagenes de maquinas
# y publicaciones van a Vercel Blob. Sin este token, cualquier subida falla con
# 500 ("No blob credentials found").
# Se saca del panel de Vercel: Storage -> Blob -> tu store -> Tokens.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxx

# Correo: el envio real va por la API de Brevo (src/services/email.service.js),
# NO por SMTP. Sin BREVO_API_KEY las invitaciones fallan con 500, y como el
# registro publico esta deshabilitado, no se pueden crear usuarios.
BREVO_API_KEY=tu-api-key-de-brevo
BREVO_SENDER_EMAIL=remitente-verificado@dominio.com

# EMAIL_FROM / EMAIL_USER se siguen usando como remitente de reserva si no se
# define BREVO_SENDER_EMAIL.
EMAIL_FROM="CRM <tu-correo@dominio.com>"
EMAIL_USER=tu-correo@dominio.com

# Las de SMTP quedan de la implementacion anterior; el servicio actual no las usa.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_PASS=tu-password-o-app-password

CORREO_USUARIO=tu-correo@dominio.com
CORREO_PASSWORD=tu-password-o-app-password
